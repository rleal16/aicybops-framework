# AICybOps Service Configuration
# Copy this file to .env and adjust values for your deployment

# Service Configuration
AICYBOPS_SERVICE_HOST=localhost
AICYBOPS_SERVICE_PORT=8000
AICYBOPS_SERVICE_PROTOCOL=http

# Data Source Configuration
DATA_SOURCE=local  # 'local' or 'api'
API_URL=http://10.2.0.76:5007  # Required when DATA_SOURCE=api

# Model Configuration (for service)
SIMPLE_CNN_MODEL_NAME=simple_cnn
AUTOENCODER_MODEL_NAME=autoencoder

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# MinIO Configuration
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123

# Database Configuration
DATABASE_URL=postgresql://mlflow:mlflow@localhost:5432/mlflow

# Service Internal Configuration
DATA_DIR=/app/data
LOCAL_DATA_SOURCE=/app/data/
CNN_AUTOENCODER_DATA_SOURCE=/app/data/main_test.csv
