# MLflow + S3 (MinIO) for run_experiments.py artifact logging.
# Copy to .env and adjust, or set in shell before running.
# With AICybOps stack: MLflow on host port 5001, MinIO on 9000.

MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
